<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONTADOR"
        android:textColor="#BB86FC"
        android:textSize="22sp"
        android:letterSpacing="0.3"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"/>

    <TextView
        android:id="@+id/tvContador"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="80sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/circulo_fondo"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <Button
        android:id="@+id/btnSumar"
        android:layout_width="160dp"
        android:layout_height="55dp"
        android:text="+ SUMAR"
        android:textColor="#121212"
        android:backgroundTint="#BB86FC"
        android:textStyle="bold"
        android:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/tvContador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"/>

    <Button
        android:id="@+id/btnRestar"
        android:layout_width="160dp"
        android:layout_height="55dp"
        android:text="- RESTAR"
        android:textColor="#121212"
        android:backgroundTint="#CF6679"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnSumar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnReset"
        android:layout_width="160dp"
        android:layout_height="55dp"
        android:text="↺ RESET"
        android:textColor="#BB86FC"
        android:backgroundTint="#1F1F1F"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnRestar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
